{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceCapturePackage",
  "type": "object",
  "required": [
    "source_id",
    "canonical_pointer",
    "retrieval_status",
    "retrieval_timestamp",
    "content_type",
    "stable_representation",
    "human_identifier"
  ],
  "properties": {
    "source_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "canonical_pointer": {
      "type": "string",
      "minLength": 1
    },
    "retrieval_status": {
      "type": "string",
      "enum": [
        "success",
        "not_found",
        "forbidden",
        "error",
        "partial"
      ]
    },
    "retrieval_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "content_type": {
      "type": "string",
      "minLength": 3
    },
    "stable_representation": {
      "type": "string",
      "minLength": 1
    },
    "human_identifier": {
      "type": "string",
      "minLength": 3
    },
    "provenance_notes": {
      "type": "string"
    },
    "linkage": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "capture_method": {
      "type": "string",
      "enum": [
        "manual-download",
        "web-capture",
        "repository-export",
        "api-fetch",
        "other-controlled"
      ]
    },
    "hash": {
      "type": "string",
      "pattern": "^[A-Za-z0-9:_-]{8,}$"
    }
  },
  "additionalProperties": false
}
