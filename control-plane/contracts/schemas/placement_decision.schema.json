{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlacementDecision",
  "type": "object",
  "required": [
    "artifact_id",
    "artifact_type",
    "placement_target",
    "rationale"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "task-packet",
        "result-packet",
        "semantic-note",
        "source-capture-package",
        "knowledge-asset",
        "observability-report"
      ]
    },
    "placement_target": {
      "type": "string",
      "enum": [
        "notion",
        "obsidian",
        "kb",
        "observability",
        "mixed"
      ]
    },
    "rationale": {
      "type": "string",
      "minLength": 10
    },
    "required_preconditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "post_placement_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "split_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact_part",
          "destination"
        ],
        "properties": {
          "artifact_part": {
            "type": "string",
            "minLength": 3
          },
          "destination": {
            "type": "string",
            "enum": [
              "notion",
              "obsidian",
              "kb",
              "observability"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
