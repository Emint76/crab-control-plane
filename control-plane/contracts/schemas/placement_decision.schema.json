{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlacementDecision",
  "type": "object",
  "required": [
    "artifact_id",
    "artifact_type",
    "placement_target",
    "rationale"
  ],
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "artifact_type": {
      "type": "string"
    },
    "placement_target": {
      "type": "string",
      "enum": [
        "notion",
        "obsidian",
        "kb",
        "observability",
        "mixed"
      ]
    },
    "rationale": {
      "type": "string"
    },
    "required_preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "post_placement_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
