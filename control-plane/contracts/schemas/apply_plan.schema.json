{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "apply_plan",
  "type": "object",
  "required": [
    "run_id",
    "plan_id",
    "generated_at",
    "engine_mode",
    "evaluation_mode",
    "status",
    "review_required",
    "target_runtime",
    "steps",
    "blockers"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "engine_mode": {
      "type": "string",
      "const": "scaffold"
    },
    "evaluation_mode": {
      "type": "string",
      "const": "static-v1"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready",
        "blocked"
      ]
    },
    "review_required": {
      "type": "boolean"
    },
    "target_runtime": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "source_ref",
          "target_path",
          "required_gate"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "copy",
              "render",
              "write",
              "skip"
            ]
          },
          "source_ref": {
            "type": "string",
            "minLength": 1
          },
          "target_path": {
            "type": "string",
            "minLength": 1
          },
          "required_gate": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
