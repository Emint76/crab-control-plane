{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "validation_report",
  "type": "object",
  "required": [
    "run_id",
    "generated_at",
    "engine_mode",
    "evaluation_mode",
    "status",
    "checks"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "engine_mode": {
      "type": "string",
      "const": "scaffold"
    },
    "evaluation_mode": {
      "type": "string",
      "const": "static-v1"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail"
            ]
          },
          "detail": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
