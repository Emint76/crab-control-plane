{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewDecision",
  "type": "object",
  "required": [
    "artifact_id",
    "decision",
    "rationale"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "decision": {
      "type": "string",
      "enum": [
        "approve",
        "return_for_revision",
        "hold",
        "reject"
      ]
    },
    "rationale": {
      "type": "string",
      "minLength": 10
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "required_changes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "approved_destination": {
      "type": "string",
      "enum": [
        "notion",
        "obsidian",
        "kb",
        "observability"
      ]
    },
    "reviewer_notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
