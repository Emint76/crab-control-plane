{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResultPacket",
  "type": "object",
  "required": [
    "task_id",
    "result_summary",
    "produced_artifacts",
    "unresolved_issues",
    "confidence",
    "evidence",
    "suggested_placement"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "result_summary": {
      "type": "string",
      "minLength": 10
    },
    "produced_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "artifact_type",
          "ref"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "artifact_type": {
            "type": "string",
            "enum": [
              "task-packet",
              "result-packet",
              "semantic-note",
              "source-capture-package",
              "knowledge-asset",
              "observability-report"
            ]
          },
          "artifact_role": {
            "type": "string",
            "enum": [
              "operational",
              "semantic",
              "source-bearing",
              "knowledge",
              "observability"
            ]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "unresolved_issues": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type",
          "ref"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "document",
              "note",
              "source-package",
              "log",
              "policy-doc"
            ]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "suggested_placement": {
      "type": "string",
      "enum": [
        "notion",
        "obsidian",
        "kb",
        "observability",
        "mixed"
      ]
    },
    "validation_report_ref": {
      "type": "string",
      "minLength": 1
    },
    "admission_decision_ref": {
      "type": "string",
      "minLength": 1
    },
    "placement_decision_ref": {
      "type": "string",
      "minLength": 1
    },
    "apply_plan_ref": {
      "type": "string",
      "minLength": 1
    },
    "suggested_followups": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  },
  "additionalProperties": false
}
