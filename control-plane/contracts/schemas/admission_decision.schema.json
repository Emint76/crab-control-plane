{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "admission_decision",
  "type": "object",
  "required": [
    "run_id",
    "generated_at",
    "engine_mode",
    "evaluation_mode",
    "decision",
    "checklist",
    "blockers"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "engine_mode": {
      "type": "string",
      "const": "scaffold"
    },
    "evaluation_mode": {
      "type": "string",
      "const": "static-v1"
    },
    "decision": {
      "type": "string",
      "enum": [
        "approved",
        "rejected",
        "needs_changes"
      ]
    },
    "checklist": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
